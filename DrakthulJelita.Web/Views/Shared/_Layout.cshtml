<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - DrakthulJelita.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/DrakthulJelita.Web.styles.css" asp-append-version="true"/>
</head>

<body>
<header>
    <nav>
        <div>
            <a asp-area="" asp-controller="Home" asp-action="Index">DrakthulJelita.Web</a>

            <div>
                <ul>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">
                            Privacy
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - DrakthulJelita.Web -
        <a asp-area="" asp-controller="Home" asp-action="Privacy">
            Privacy
        </a>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", false)
</body>
</html>
